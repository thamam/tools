{
  "name": "markdown-codelens-runner",
  "displayName": "Markdown Code Lens Runner",
  "description": "Adds Copy and Run in Terminal CodeLens actions above fenced code blocks in Markdown files",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownCodeLens.copy",
        "title": "Markdown: Copy Code Block"
      },
      {
        "command": "markdownCodeLens.runInTerminal",
        "title": "Markdown: Run Code Block in Terminal"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
